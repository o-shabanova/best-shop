{
  "name": "fundamentals-project-ts-template",
  "version": "1.0.0",
  "description": "Capstone Project TS Template",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "ts-compile": "npx tsc",
    "start": "serve src -l 5173",
    "start:dist": "serve dist -l 5173",
    "build:css": "sass src/scss/main.scss dist/css/main.css --style=expanded --no-source-map",
    "watch:css": "sass --watch src/scss/main.scss:dist/css/main.css --style=expanded",
    "build:html": "node build-html.mjs",
    "build": "npm run clean && npm run build:css && npm run build:html",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "posthtml": "^0.16.7",
    "posthtml-include": "^2.0.1",
    "sass": "^1.99.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.2"
  }
}
